{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "lib": [
            "DOM",
            "ES2024"
        ],
        "module": "NodeNext",
        "moduleDetection": "force",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "noImplicitAny": false,
        "strict": true,
        "target": "ES2024",
        "types": [
            "node",
            "vitest"
        ]
    },
    "exclude": [
        "dist",
        "node_modules"
    ],
    "include": [
        "bin/**/*.ts",
        "docs/**/*.ts",
        "src/**/*.ts",
        "test/**/*.ts",
        "tools/**/*.ts",
        "types/**/*.d.ts"
    ]
}
